{
  "openapi": "3.0.3",
  "info": {
    "title": "Restaurant Booking API",
    "version": "1.0.0"
  },
  "servers": [{ "url": "http://localhost:5177" }],
  "paths": {
    "/api/auth/csrf": {
      "get": {
        "operationId": "getCsrfToken",
        "tags": ["Auth"],
        "responses": {
          "200": {
            "description": "CSRF token",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CsrfResponse" }
              }
            }
          }
        }
      }
    },
    "/api/auth/me": {
      "get": {
        "operationId": "getCurrentUser",
        "tags": ["Auth"],
        "responses": {
          "200": {
            "description": "Current user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CurrentUserResponse" }
              }
            }
          },
          "401": { "description": "Unauthenticated" }
        }
      }
    },
    "/api/auth/register": {
      "post": {
        "operationId": "register",
        "tags": ["Auth"],
        "parameters": [{ "$ref": "#/components/parameters/CsrfHeader" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Registered user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CurrentUserResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "operationId": "login",
        "tags": ["Auth"],
        "parameters": [{ "$ref": "#/components/parameters/CsrfHeader" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AuthRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logged-in user",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CurrentUserResponse" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "operationId": "logout",
        "tags": ["Auth"],
        "parameters": [{ "$ref": "#/components/parameters/CsrfHeader" }],
        "responses": {
          "204": { "description": "Logged out" },
          "400": { "$ref": "#/components/responses/Error" },
          "401": { "description": "Unauthenticated" }
        }
      }
    },
    "/api/restaurants": {
      "get": {
        "operationId": "listRestaurants",
        "tags": ["Restaurants"],
        "responses": {
          "200": {
            "description": "Restaurants",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Restaurant" }
                }
              }
            }
          }
        }
      }
    },
    "/api/restaurants/{restaurantId}/availability": {
      "get": {
        "operationId": "listAvailableSlots",
        "tags": ["Availability"],
        "parameters": [
          {
            "name": "restaurantId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "date",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "partySize",
            "in": "query",
            "required": true,
            "schema": { "type": "integer", "format": "int32" }
          }
        ],
        "responses": {
          "200": {
            "description": "Available slots",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/AvailabilitySlot" }
                }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" },
          "404": { "$ref": "#/components/responses/Error" }
        }
      }
    },
    "/api/bookings": {
      "get": {
        "operationId": "listBookings",
        "tags": ["Bookings"],
        "parameters": [
          {
            "name": "restaurantId",
            "in": "query",
            "required": false,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Authenticated user's bookings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Booking" }
                }
              }
            }
          },
          "401": { "description": "Unauthenticated" }
        }
      },
      "post": {
        "operationId": "createBooking",
        "tags": ["Bookings"],
        "parameters": [{ "$ref": "#/components/parameters/CsrfHeader" }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateBookingRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created booking",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Booking" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/Error" },
          "401": { "description": "Unauthenticated" },
          "404": { "$ref": "#/components/responses/Error" },
          "409": { "$ref": "#/components/responses/Error" }
        }
      }
    }
  },
  "components": {
    "parameters": {
      "CsrfHeader": {
        "name": "X-CSRF-TOKEN",
        "in": "header",
        "required": true,
        "schema": { "type": "string" }
      }
    },
    "responses": {
      "Error": {
        "description": "Business error",
        "content": {
          "application/json": {
            "schema": { "$ref": "#/components/schemas/ErrorResponse" }
          }
        }
      }
    },
    "schemas": {
      "AuthRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "format": "password" }
        }
      },
      "CurrentUserResponse": {
        "type": "object",
        "required": ["email"],
        "properties": {
          "email": { "type": "string", "format": "email" }
        }
      },
      "CsrfResponse": {
        "type": "object",
        "required": ["token"],
        "properties": {
          "token": { "type": "string" }
        }
      },
      "Restaurant": {
        "type": "object",
        "required": [
          "id",
          "name",
          "cuisine",
          "neighborhood",
          "description",
          "tables"
        ],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "cuisine": { "type": "string" },
          "neighborhood": { "type": "string" },
          "description": { "type": "string" },
          "tables": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/Table" }
          }
        }
      },
      "Table": {
        "type": "object",
        "required": ["id", "capacity"],
        "properties": {
          "id": { "type": "string" },
          "capacity": { "type": "integer", "format": "int32" }
        }
      },
      "Booking": {
        "type": "object",
        "required": [
          "id",
          "restaurantId",
          "restaurantName",
          "tableId",
          "partySize",
          "date",
          "time",
          "guestName",
          "guestEmail"
        ],
        "properties": {
          "id": { "type": "string" },
          "restaurantId": { "type": "string" },
          "restaurantName": { "type": "string" },
          "tableId": { "type": "string" },
          "partySize": { "type": "integer", "format": "int32" },
          "date": { "type": "string", "format": "date" },
          "time": { "type": "string", "example": "17:00:00" },
          "guestName": { "type": "string" },
          "guestEmail": { "type": "string" }
        }
      },
      "CreateBookingRequest": {
        "type": "object",
        "required": [
          "restaurantId",
          "date",
          "time",
          "partySize",
          "guestName",
          "guestEmail"
        ],
        "properties": {
          "restaurantId": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "time": { "type": "string", "example": "17:00:00" },
          "partySize": { "type": "integer", "format": "int32" },
          "guestName": { "type": "string" },
          "guestEmail": { "type": "string" }
        }
      },
      "AvailabilitySlot": {
        "type": "object",
        "required": ["time", "availableTableCount"],
        "properties": {
          "time": { "type": "string", "example": "17:00:00" },
          "availableTableCount": { "type": "integer", "format": "int32" }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    }
  }
}

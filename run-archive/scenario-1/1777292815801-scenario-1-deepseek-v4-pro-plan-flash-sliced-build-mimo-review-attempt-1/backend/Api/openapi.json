{
  "openapi": "3.1.1",
  "info": {
    "title": "Restaurant Booking API",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "/api", "description": "API server" }
  ],
  "paths": {
    "/restaurants": {
      "get": {
        "tags": ["Restaurants"],
        "operationId": "getRestaurants",
        "summary": "List all restaurants",
        "responses": {
          "200": {
            "description": "List of restaurants",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Restaurant" }
                }
              }
            }
          }
        }
      }
    },
    "/restaurants/{id}": {
      "get": {
        "tags": ["Restaurants"],
        "operationId": "getRestaurant",
        "summary": "Get a restaurant by ID",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "Restaurant details",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Restaurant" }
              }
            }
          }
        }
      }
    },
    "/restaurants/{id}/tables": {
      "get": {
        "tags": ["Restaurants"],
        "operationId": "getRestaurantTables",
        "summary": "List tables for a restaurant",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of tables",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Table" }
                }
              }
            }
          }
        }
      }
    },
    "/restaurants/{id}/slots": {
      "get": {
        "tags": ["Restaurants"],
        "operationId": "getAvailableSlots",
        "summary": "Get available time slots",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "date",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "partySize",
            "in": "query",
            "required": true,
            "schema": { "type": "integer", "format": "int32" }
          }
        ],
        "responses": {
          "200": {
            "description": "Available time slots (HH:mm)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              }
            }
          }
        }
      }
    },
    "/restaurants/{id}/bookings": {
      "get": {
        "tags": ["Bookings"],
        "operationId": "getRestaurantBookings",
        "summary": "List bookings for a restaurant on a date",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "date",
            "in": "query",
            "required": true,
            "schema": { "type": "string", "format": "date" }
          }
        ],
        "responses": {
          "200": {
            "description": "List of bookings",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": { "$ref": "#/components/schemas/Booking" }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Bookings"],
        "operationId": "createBooking",
        "summary": "Create a new booking",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CreateBookingRequest" }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Booking created successfully",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/Booking" }
              }
            }
          },
          "400": {
            "description": "Bad request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiError" }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiError" }
              }
            }
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ApiError" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Restaurant": {
        "type": "object",
        "required": ["id", "name", "cuisine", "address"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "cuisine": { "type": "string" },
          "address": { "type": "string" }
        }
      },
      "Table": {
        "type": "object",
        "required": ["id", "restaurantId", "capacity", "label"],
        "properties": {
          "id": { "type": "string" },
          "restaurantId": { "type": "string" },
          "capacity": { "type": "integer", "format": "int32" },
          "label": { "type": "string" }
        }
      },
      "Booking": {
        "type": "object",
        "required": ["id", "restaurantId", "tableId", "guestName", "guestEmail", "partySize", "dateTime", "duration"],
        "properties": {
          "id": { "type": "string" },
          "restaurantId": { "type": "string" },
          "tableId": { "type": "string" },
          "guestName": { "type": "string" },
          "guestEmail": { "type": "string" },
          "partySize": { "type": "integer", "format": "int32" },
          "dateTime": { "type": "string", "format": "date-time" },
          "duration": { "type": "string" }
        }
      },
      "CreateBookingRequest": {
        "type": "object",
        "required": ["guestName", "guestEmail", "partySize", "dateTime"],
        "properties": {
          "guestName": { "type": "string" },
          "guestEmail": { "type": "string" },
          "partySize": { "type": "integer", "format": "int32" },
          "dateTime": { "type": "string", "format": "date-time" }
        }
      },
      "ApiError": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      }
    }
  },
  "tags": [
    { "name": "Restaurants", "description": "Restaurant operations" },
    { "name": "Bookings", "description": "Booking operations" }
  ]
}

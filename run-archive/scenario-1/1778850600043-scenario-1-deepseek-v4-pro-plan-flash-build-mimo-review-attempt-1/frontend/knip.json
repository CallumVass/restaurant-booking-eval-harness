{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "entry": ["src/App.tsx", "src/pages/*.tsx"],
  "project": ["src/**/*.ts", "src/**/*.tsx"],
  "ignoreDependencies": [
    "tailwindcss",
    "tw-animate-css",
    "@radix-ui/react-dialog",
    "@radix-ui/react-select",
    "date-fns"
  ],
  "ignore": [
    "src/api/generated/**",
    "src/components/ui/*.tsx"
  ]
}

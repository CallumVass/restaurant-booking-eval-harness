{
  "openapi": "3.1.1",
  "info": {
    "title": "RestaurantBooking.Api | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:5088/"
    }
  ],
  "paths": {
    "/": {
      "get": {
        "tags": ["RestaurantBooking.Api"],
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      }
    },
    "/restaurants": {
      "get": {
        "tags": ["RestaurantBooking.Api"],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RestaurantDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/restaurants/{restaurantId}/timeslots": {
      "get": {
        "tags": ["RestaurantBooking.Api"],
        "parameters": [
          {
            "name": "restaurantId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          },
          {
            "name": "date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "partySize",
            "in": "query",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": ["integer", "string"],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TimeSlotDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/bookings": {
      "get": {
        "tags": ["RestaurantBooking.Api"],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BookingDto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["RestaurantBooking.Api"],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBookingRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BookingDto"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BookingDto": {
        "required": [
          "id",
          "restaurantId",
          "tableId",
          "guestName",
          "partySize",
          "start",
          "end"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "restaurantId": {
            "type": "string",
            "format": "uuid"
          },
          "tableId": {
            "type": "string",
            "format": "uuid"
          },
          "guestName": {
            "type": "string"
          },
          "partySize": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": ["integer", "string"],
            "format": "int32"
          },
          "start": {
            "type": "string",
            "format": "date-time"
          },
          "end": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CreateBookingRequest": {
        "required": ["restaurantId", "guestName", "partySize", "start"],
        "type": "object",
        "properties": {
          "restaurantId": {
            "type": "string",
            "format": "uuid"
          },
          "guestName": {
            "type": "string"
          },
          "partySize": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": ["integer", "string"],
            "format": "int32"
          },
          "start": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RestaurantDto": {
        "required": ["id", "name", "description", "neighborhood", "tables"],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "neighborhood": {
            "type": "string"
          },
          "tables": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/TableDto"
            }
          }
        }
      },
      "TableDto": {
        "required": ["id", "capacity"],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "capacity": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": ["integer", "string"],
            "format": "int32"
          }
        }
      },
      "TimeSlotDto": {
        "required": ["start", "available", "tableCapacity"],
        "type": "object",
        "properties": {
          "start": {
            "type": "string",
            "format": "date-time"
          },
          "available": {
            "type": "boolean"
          },
          "tableCapacity": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": ["null", "integer", "string"],
            "format": "int32"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "RestaurantBooking.Api"
    }
  ]
}

{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/mimo-v2.5",
  "agent": {
    "plan": {
      "model": "opencode-go/mimo-v2.5-pro",
      "reasoningEffort": "high"
    },
    "eval-planner": {
      "model": "opencode-go/mimo-v2.5-pro",
      "mode": "subagent",
      "description": "Writes a concise implementation plan for the restaurant booking eval before build.",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "deny",
        "external_directory": {
          "/tmp/*": "allow",
          "*": "deny"
        },
        "webfetch": "allow",
        "skill": "allow"
      },
      "reasoningEffort": "high"
    },
    "plan-reviewer": {
      "model": "opencode-go/deepseek-v4-pro",
      "mode": "subagent",
      "description": "Reviews whether the implementation followed the saved plan and scenario requirements.",
      "permission": {
        "read": "allow",
        "edit": "deny",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "allow",
        "external_directory": {
          "/tmp/*": "allow",
          "*": "deny"
        },
        "webfetch": "allow",
        "skill": "allow"
      },
      "reasoningEffort": "high"
    },
    "build": {
      "model": "opencode-go/mimo-v2.5",
      "permission": {
        "external_directory": {
          "/tmp/*": "allow",
          "*": "deny"
        }
      },
      "reasoningEffort": "medium"
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "external_directory": {
      "/tmp/*": "allow",
      "*": "deny"
    },
    "webfetch": "allow"
  },
  "snapshot": false
}

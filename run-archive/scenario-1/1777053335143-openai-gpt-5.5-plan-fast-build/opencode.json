{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.5-fast",
  "agent": {
    "plan": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "xhigh",
      "textVerbosity": "low"
    },
    "eval-planner": {
      "model": "openai/gpt-5.5",
      "mode": "subagent",
      "description": "Writes a concise implementation plan for the restaurant booking eval before build.",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "deny",
        "external_directory": {
          "/tmp/*": "allow",
          "*": "deny"
        },
        "webfetch": "allow",
        "skill": "allow"
      },
      "reasoningEffort": "xhigh",
      "textVerbosity": "low"
    },
    "build": {
      "model": "openai/gpt-5.5-fast",
      "permission": {
        "external_directory": {
          "/tmp/*": "allow",
          "*": "deny"
        }
      },
      "reasoningEffort": "medium",
      "textVerbosity": "low"
    }
  },
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "external_directory": {
      "/tmp/*": "allow",
      "*": "deny"
    },
    "webfetch": "allow"
  },
  "snapshot": false
}

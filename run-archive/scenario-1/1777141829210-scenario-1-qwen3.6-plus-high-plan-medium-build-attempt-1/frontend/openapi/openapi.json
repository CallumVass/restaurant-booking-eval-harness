{
  "openapi": "3.1.1",
  "info": {
    "title": "Api | v1",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:5053/"
    }
  ],
  "paths": {
    "/api/restaurants": {
      "get": {
        "tags": [
          "Restaurants"
        ],
        "operationId": "GetRestaurants",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/RestaurantResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/restaurants/{id}/slots": {
      "get": {
        "tags": [
          "Restaurants"
        ],
        "operationId": "GetAvailableSlots",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "date",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "format": "date"
            }
          },
          {
            "name": "partySize",
            "in": "query",
            "required": true,
            "schema": {
              "pattern": "^-?(?:0|[1-9]\\d*)$",
              "type": [
                "integer",
                "string"
              ],
              "format": "int32"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TimeSlotResponse"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/bookings": {
      "post": {
        "tags": [
          "Bookings"
        ],
        "operationId": "CreateBooking",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateBookingRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "get": {
        "tags": [
          "Bookings"
        ],
        "operationId": "GetBookings",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/BookingResponse"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BookingResponse": {
        "required": [
          "id",
          "restaurantId",
          "guestName",
          "guestEmail",
          "partySize",
          "dateTime",
          "durationMinutes"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "restaurantId": {
            "type": "string"
          },
          "guestName": {
            "type": "string"
          },
          "guestEmail": {
            "type": "string"
          },
          "partySize": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "dateTime": {
            "type": "string",
            "format": "date-time"
          },
          "durationMinutes": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "CreateBookingRequest": {
        "required": [
          "restaurantId",
          "guestName",
          "guestEmail",
          "partySize",
          "dateTime"
        ],
        "type": "object",
        "properties": {
          "restaurantId": {
            "type": "string"
          },
          "guestName": {
            "type": "string"
          },
          "guestEmail": {
            "type": "string"
          },
          "partySize": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "dateTime": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "RestaurantResponse": {
        "required": [
          "id",
          "name",
          "description",
          "cuisine",
          "maxCapacity"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "cuisine": {
            "type": "string"
          },
          "maxCapacity": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          }
        }
      },
      "TimeSlotResponse": {
        "required": [
          "time",
          "isAvailable"
        ],
        "type": "object",
        "properties": {
          "time": {
            "type": "string",
            "format": "date-time"
          },
          "isAvailable": {
            "type": "boolean"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Restaurants"
    },
    {
      "name": "Bookings"
    }
  ]
}